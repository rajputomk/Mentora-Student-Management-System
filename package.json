{
    "name": "monorepo",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "npm run dev --prefix apps/web",
        "build": "concurrently --raw \"npm run build --prefix apps/web\"",
        "start": "concurrently --kill-others --raw \"npm run start --prefix apps/pocketbase\"",
        "lint": "concurrently --raw \"npm run lint --prefix apps/web\""
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    },
    "workspaces": [
        "apps/*"
    ],
    "dependencies": {
        "@supabase/supabase-js": "^2.105.4"
    }
}
